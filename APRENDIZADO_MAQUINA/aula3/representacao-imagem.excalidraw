			"text": "Cor",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Cor",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"rawText": ""
		},
		{
			"id": "suQy8pZB",
			"type": "text",
			"x": 1027.0267583882426,
			"y": 523.3931958628264,
			"width": 435.45923838325274,
			"height": 160,
			"angle": 0,
			"strokeColor": "#1e1e1e",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 2,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"index": "b0x",
			"roundness": null,
			"seed": 1912829433,
			"version": 505,
			"versionNonce": 1734280025,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1773758698823,
			"link": null,
			"locked": false,
			"text": "Oferece informações adicionais que podem ser\ndiscriminativas e complementares.\n- Histogramas de cor representam a distribuição das\ncores em uma imagem e são invariantes a rotação e\nescala.\n- Modelos de cor:\n    - RGB: mais comum, mas sensível à iluminação.\n    - HSV: separa a matiz, saturação e brilho.",
			"fontSize": 16,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Oferece informações adicionais que podem ser\ndiscriminativas e complementares.\n- Histogramas de cor representam a distribuição das\ncores em uma imagem e são invariantes a rotação e\nescala.\n- Modelos de cor:\n    - RGB: mais comum, mas sensível à iluminação.\n    - HSV: separa a matiz, saturação e brilho.",
			"autoResize": false,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"rawText": ""
		},
		{
			"id": "4LN0m7R7",
			"type": "text",
			"x": 1023.9737295598195,
			"y": 694.1941193006327,
			"width": 94.59989929199219,
			"height": 25,
			"angle": 0,
			"strokeColor": "#f08c00",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 2,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"index": "b0y",
			"roundness": null,
			"seed": 1591322711,
			"version": 310,
