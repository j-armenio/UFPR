			"isDeleted": false,
			"boundElements": [],
			"updated": 1773758202427,
			"link": null,
			"locked": false,
			"text": "Também conhecido como eixo medial, é uma representação reduzida de uma\nforma que preserva sua estrutura topológica enquanto minimiza a\nredundância. Extrai as linhas centrais.",
			"fontSize": 16,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Também conhecido como eixo medial, é uma representação reduzida de uma\nforma que preserva sua estrutura topológica enquanto minimiza a\nredundância. Extrai as linhas centrais.",
			"autoResize": false,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"rawText": ""
		},
