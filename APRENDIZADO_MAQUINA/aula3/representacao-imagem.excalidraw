			"isDeleted": false,
			"boundElements": [],
			"updated": 1773758945775,
			"link": null,
			"locked": false,
			"text": "Gradiente",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Gradiente",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"rawText": ""
		},
		{
			"id": "A9AsfWjU",
			"type": "text",
			"x": 1023.9712311273172,
			"y": 719.4229165515968,
			"width": 439.63252220528926,
			"height": 180,
			"angle": 0,
			"strokeColor": "#1e1e1e",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 2,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"index": "b0z",
			"roundness": null,
			"seed": 806421175,
			"version": 479,
			"versionNonce": 1500205625,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1773758913242,
			"link": null,
			"locked": false,
			"text": "Vetor que aponta na direção de maior variação da\nintensidade, cujo módulo (ou magnitude) indica o quão\nrápida é essa variação.\n- Variações abruptas geralmente se encontram nas\nbordas dos objetos.\n- Principais representações baseadas em gradientes:\n    - SIFT (Scale-Invariant Feature Transform)\n    - SURF (Speeded-Up Robust Features)\n    - ORB (Oriented FAST and Rotated BRIEF)",
			"fontSize": 16,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Vetor que aponta na direção de maior variação da\nintensidade, cujo módulo (ou magnitude) indica o quão\nrápida é essa variação.\n- Variações abruptas geralmente se encontram nas\nbordas dos objetos.\n- Principais representações baseadas em gradientes:\n    - SIFT (Scale-Invariant Feature Transform)\n    - SURF (Speeded-Up Robust Features)\n    - ORB (Oriented FAST and Rotated BRIEF)",
			"autoResize": false,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"rawText": ""
		},
