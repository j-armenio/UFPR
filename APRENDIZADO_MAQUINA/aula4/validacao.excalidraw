    {
      "id": "b6fK9bNy",
      "type": "text",
      "x": 355.20632119717186,
      "y": 327.1027840036899,
      "width": 285.10780843098956,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
