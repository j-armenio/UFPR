    {
      "id": "oBlpSZLt",
      "type": "text",
      "x": 907.8025272111327,
      "y": 907.1603533227133,
      "width": 482.01171457394196,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "az",
      "roundness": null,
      "seed": 1420355459,
      "version": 347,
      "versionNonce": 1828797773,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775257003586,
      "locked": false,
      "text": "Em séries temporais, são necessários validações diferentes\ndevido a natureza dos dados (tempo-dependente).\nDados devem manter uma ordem cronológica.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Em séries temporais, são necessários validações diferentes\ndevido a natureza dos dados (tempo-dependente).\nDados devem manter uma ordem cronológica.",
      "autoResize": false,
      "lineHeight": 1.25,
