    {
      "id": "6zboOS1bruJR9wiEiSTYV",
      "type": "text",
      "x": 45.848959657131644,
      "y": 310.12422640014887,
      "width": 167.98689786340955,
      "height": 127.17403891351893,
      "angle": 6.1737183553466775,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
