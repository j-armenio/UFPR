      "isDeleted": false,
      "boundElements": [],
      "updated": 1773091226053,
      "link": null,
      "locked": false,
      "text": "se existe um programa\npara um modelo que resolve\ninstâncias de um problema,\nexiste um programa\nequivalente que resolve\ninstâncias desse problema\npara qualquer um dos\noutros modelos",
      "fontSize": 12.717403891351893,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "se existe um programa para um modelo que resolve instâncias de um problema, existe um programa equivalente que resolve instâncias desse problema para qualquer um dos outros modelos",
      "autoResize": false,
      "lineHeight": 1.25
    },
