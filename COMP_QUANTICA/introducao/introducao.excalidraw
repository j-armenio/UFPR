      "updated": 1773091052579,
      "link": null,
      "locked": false,
      "text": "Além disso, todos eles, com excessão do Modelo de Circuitos\nQuânticos, são polinomialmente equivalentes.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Além disso, todos eles, com excessão do Modelo de Circuitos Quânticos, são polinomialmente equivalentes.",
