    {
      "id": "CwK2u15hoVu_Qf3_decfU",
      "type": "text",
      "x": 374,
      "y": 258.5,
      "width": 560.6638781251332,
      "height": 260,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a1",
      "roundness": null,
      "seed": 214836171,
      "version": 775,
      "versionNonce": 243790891,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772731787093,
      "link": null,
      "locked": false,
      "text": "Forma como os dados são apresentados ou estruturados para o modelo\nde aprendizagem de máquina.\n\n- Cada exemplo é representado como um vetor de características\n(feature vector).\n- Cada característica é uma dimensão.\n- A qualidadade da representação influencia diretamente a capacidade\ndo modelo de aprender padrões úteis. O modelo só é tão bom quanto a\nrepresentação dos dados.\n\nReduz a complexidade do problema, captura informações importantes,\ndescarta ruídos, permite generalização e facilita convergência e\ndesempenho.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Forma como os dados são apresentados ou estruturados para o modelo de aprendizagem de máquina.\n\n- Cada exemplo é representado como um vetor de características (feature vector).\n- Cada característica é uma dimensão.\n- A qualidadade da representação influencia diretamente a capacidade do modelo de aprender padrões úteis. O modelo só é tão bom quanto a representação dos dados.\n\nReduz a complexidade do problema, captura informações importantes, descarta ruídos, permite generalização e facilita convergência e desempenho.",
      "autoResize": false,
      "lineHeight": 1.25
    },
