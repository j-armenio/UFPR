      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Quanto maior q, são necessárias mais amostras exponencialmente.\nE quanto maior d(q,N) mais enviesadas são as estimativas.",
      "autoResize": false,
      "lineHeight": 1.25
    },
