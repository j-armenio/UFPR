      "boundElements": [],
      "updated": 1772993742011,
      "link": null,
      "locked": false,
      "text": "Bom para dados não estacionários (séries temporais cujas média,\nvariância, estrutura de autocorrelação, etc) não se mantem constantes.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Bom para dados não estacionários (séries temporais cujas média, variância, estrutura de autocorrelação, etc) não se mantem constantes.",
