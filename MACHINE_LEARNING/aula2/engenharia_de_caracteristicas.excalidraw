    {
      "id": "J6AEKZ_xPjaSjya4NrnA4",
      "type": "text",
      "x": 380.66688749723505,
      "y": 1134.8053941869002,
      "width": 564.5375603577515,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ced4da",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aW",
      "roundness": null,
      "seed": 128100069,
      "version": 543,
      "versionNonce": 581333605,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "V8KMtsBcfBeppuiizYMaS",
          "type": "arrow"
        }
      ],
      "updated": 1772732925636,
      "link": null,
      "locked": false,
      "text": "Depende da complexidade do problema:\n- Exigência de acurácia: 60% de acurácia eixge menos dados de\ntreinamento que 95%\n- Dimensionalidade do espaço de variáveis: 2 dimensões exigem menos\nque 2000 variáveis.\n- Qualidade do conjunto de treinamento: se a acurácia inicial é válida e\npode ocorrer concept drift.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Depende da complexidade do problema:\n- Exigência de acurácia: 60% de acurácia eixge menos dados de treinamento que 95%\n- Dimensionalidade do espaço de variáveis: 2 dimensões exigem menos que 2000 variáveis.\n- Qualidade do conjunto de treinamento: se a acurácia inicial é válida e pode ocorrer concept drift.",
      "autoResize": false,
      "lineHeight": 1.25
    },
