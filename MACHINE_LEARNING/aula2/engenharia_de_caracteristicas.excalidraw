      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Alguns modelos são sensíveis a dados numéricos com diferentes escalas ou distribuições assimétricas, logo algumas transformações serem para normalizar os dados.",
      "autoResize": false,
      "lineHeight": 1.25
    },
