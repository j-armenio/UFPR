      "isDeleted": false,
      "boundElements": null,
      "updated": 1772988226182,
      "link": null,
      "locked": false,
      "text": "Substitui os valores faltantes pela média, mediana ou moda.\n- Distorcem a distribuição da característica.\n- Uso em MCAR e <5% de dados faltantes",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Substitui os valores faltantes pela média, mediana ou moda.\n- Distorcem a distribuição da característica.\n- Uso em MCAR e <5% de dados faltantes",
      "autoResize": false,
      "lineHeight": 1.25
