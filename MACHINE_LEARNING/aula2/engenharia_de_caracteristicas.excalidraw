    },
    {
      "id": "r0Pbzms2aYoULU27Wj8Dn",
      "type": "text",
      "x": 2297.419222148101,
      "y": 1217.5502553786837,
      "width": 557.2727144663531,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2M",
      "roundness": null,
      "seed": 1020322927,
      "version": 416,
      "versionNonce": 1257264577,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772990786311,
      "link": null,
      "locked": false,
      "text": "Variáveis que assumem a forma de funções.\n- Análise de dados funcionais (FDA), em que cada observação é uma\nfunção. ex: curvas de temperatura, série temporal, dados espectrais).\n- São tipicamente contínuos, de alta dimensão e muitas vezes suaves.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Variáveis que assumem a forma de funções.\n- Análise de dados funcionais (FDA), em que cada observação é uma função. ex: curvas de temperatura, série temporal, dados espectrais).\n- São tipicamente contínuos, de alta dimensão e muitas vezes suaves.",
      "autoResize": false,
      "lineHeight": 1.25
    },
