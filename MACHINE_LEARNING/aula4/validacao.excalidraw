			"link": null,
			"rawText": ""
		},
		{
			"id": "yQzx6qsO",
			"type": "text",
			"x": 354.48212886820056,
			"y": 543.4182379169868,
			"width": 244.8399248328197,
			"height": 180,
			"angle": 0,
			"strokeColor": "#1e1e1e",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 2,
			"strokeStyle": "solid",
			"roughness": 1,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"index": "aT",
			"roundness": null,
			"seed": 20222349,
			"version": 1192,
			"versionNonce": 1757198883,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1775256443189,
			"locked": false,
			"text": "Dividir os dados de\ntreinamento em k partes iguais.\n- O treinamento é realizado\ncom k-1 partes.\n- O processo é repetido k\nvezes.\n- A parte não utilizada no\ntreinamento é utilizada para\nvalidação.",
			"fontSize": 16,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Dividir os dados de\ntreinamento em k partes iguais.\n- O treinamento é realizado\ncom k-1 partes.\n- O processo é repetido k\nvezes.\n- A parte não utilizada no\ntreinamento é utilizada para\nvalidação.",
			"autoResize": false,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"link": null,
			"rawText": ""
		},
