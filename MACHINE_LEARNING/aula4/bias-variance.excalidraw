    {
      "id": "DIGZATJHa5BZvioaTvRDl",
      "type": "text",
      "x": 192.66373957610517,
      "y": 802.3318704431804,
      "width": 311.41224140651525,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1U",
      "roundness": null,
      "seed": 2137148126,
      "version": 427,
      "versionNonce": 209889182,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774451070533,
      "link": null,
      "locked": false,
      "text": "- No modelo em over-fitting, o erro é\nmuito baixo.\n- No modelo em under-fitting, o erro é\nmuito alto.\nBuscamos um modelo balanceado, com\nbaixa variância e baixo viés.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- No modelo em over-fitting, o erro é muito baixo.\n- No modelo em under-fitting, o erro é muito alto.\nBuscamos um modelo balanceado, com baixa variância e baixo viés.",
      "autoResize": false,
      "lineHeight": 1.25
    },
