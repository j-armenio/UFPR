    {
      "id": "JwLwkNz_n2NHKEFKG5izw",
      "type": "text",
      "x": 193.15753028737277,
      "y": -207.14757430290484,
      "width": 546.7029492188351,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aD",
      "roundness": null,
      "seed": 1993370526,
      "version": 344,
      "versionNonce": 65200898,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774451070533,
      "link": null,
      "locked": false,
      "text": "- Viés: devido a simplificações excessivas do modelo (under-fitting)\n- Variância: devido a sensibilidade excessiva do modelo (over-fitting)\n\nDurante o treinamento de um modelo, o objetivo é encontrar um bom\ncompromisso entre o viés e a variância.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Viés: devido a simplificações excessivas do modelo (under-fitting)\n- Variância: devido a sensibilidade excessiva do modelo (over-fitting)\n\nDurante o treinamento de um modelo, o objetivo é encontrar um bom compromisso entre o viés e a variância.",
      "autoResize": false,
      "lineHeight": 1.25
    },
