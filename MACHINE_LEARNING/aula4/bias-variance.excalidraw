      "isDeleted": false,
      "boundElements": [],
      "updated": 1774451070533,
      "link": null,
      "locked": false,
      "text": "Baixa variância: o erro no teste não muda muito em função da\nseleção aleatória dos dados, porém tem menos acertos.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Baixa variância: o erro no teste não muda muito em função da seleção aleatória dos dados, porém tem menos acertos.",
      "autoResize": false,
      "lineHeight": 1.25
    },
