    {
      "id": "qUZoAk4hku3XGbHKCu83b",
      "type": "text",
      "x": 976.4358619907232,
      "y": 275.0428244361066,
      "width": 580.1777871631572,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ah",
      "roundness": null,
      "seed": 320886748,
      "version": 393,
      "versionNonce": 2040078172,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773695630786,
      "link": null,
      "locked": false,
      "text": "- O treinamento (não supervisionado) é baseado em pares de palavras\nextraídos do texto.\n- A quantidade de pares é definido pelo tamanho da vizinhança.\n- O modelo aprenderá as estatísticas a partir do número que cada par\naparece na base de treinamento.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- O treinamento (não supervisionado) é baseado em pares de palavras extraídos do texto.\n- A quantidade de pares é definido pelo tamanho da vizinhança.\n- O modelo aprenderá as estatísticas a partir do número que cada par aparece na base de treinamento.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "9rMMERoFzTo2FUtNMC2eO",
      "type": "image",
      "x": 1097.1877639743839,
      "y": 384.199243827081,
      "width": 327.31862119906873,
      "height": 204.92028738351172,
      "angle": 0,
      "strokeColor": "transparent",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
