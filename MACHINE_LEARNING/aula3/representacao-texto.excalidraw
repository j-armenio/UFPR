      "updated": 1773696303421,
      "link": null,
      "locked": false,
      "text": "Representa palavras como vetores de números reais, de forma que palavras\ncom significados semelhantes fiquem próximas no espaço vetorial.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Representa palavras como vetores de números reais, de forma que palavras com significados semelhantes fiquem próximas no espaço vetorial.",
      "autoResize": false,
      "lineHeight": 1.25
    },
