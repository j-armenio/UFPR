    {
      "id": "LIWMt9X4Ea9w2Yuw50lPN",
      "type": "text",
      "x": 977.8219938804523,
      "y": 881.1711401087796,
      "width": 574.1255630386319,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
