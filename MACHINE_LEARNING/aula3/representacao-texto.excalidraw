    {
      "id": "3c8VUWrwmwIpBVj96CqSL",
      "type": "text",
      "x": 378.8145356495148,
      "y": 1767.195569227373,
      "width": 581.9832216930425,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ad",
      "roundness": null,
      "seed": 1269566634,
      "version": 649,
      "versionNonce": 1896585828,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773696303421,
      "link": null,
      "locked": false,
      "text": "Modelo baseado em uma rede neural com uma camada escondida que:\n    - a entrada é um \"hot-vector\" do tamanho do vocabulário\n    - a saída tem o mesmo tamanho da entrada\n    - a camada escondida é um parâmetro (tamanho do vetor pelo qual\ncada palavra será representada)\nA camada escondida não tem função de ativação.\nA camada de saída utiliza soft-max (garante que a soma de todas saídas\nsejam = 1)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Modelo baseado em uma rede neural com uma camada escondida que:\n    - a entrada é um \"hot-vector\" do tamanho do vocabulário\n    - a saída tem o mesmo tamanho da entrada\n    - a camada escondida é um parâmetro (tamanho do vetor pelo qual cada palavra será representada)\nA camada escondida não tem função de ativação.\nA camada de saída utiliza soft-max (garante que a soma de todas saídas sejam = 1)",
      "autoResize": false,
      "lineHeight": 1.25
    },
